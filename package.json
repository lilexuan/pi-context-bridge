{
  "name": "pi-context-bridge-monorepo",
  "version": "0.1.2",
  "private": true,
  "description": "Share live VS Code editor context with Pi coding agent sessions running in any local terminal.",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "corepack pnpm -r build",
    "typecheck": "corepack pnpm -r typecheck",
    "lint": "eslint .",
    "test": "vitest run",
    "test:memory": "node --expose-gc scripts/memory-stress.mjs",
    "test:watch": "vitest",
    "package:vscode": "corepack pnpm --filter pi-context-bridge-vscode package",
    "package:pi": "corepack pnpm --filter pi-context-bridge build && corepack pnpm --filter pi-context-bridge pack"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vitest": "^4.0.14"
  }
}
